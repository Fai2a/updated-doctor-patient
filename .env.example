# Copy to .env and fill in real values. Also set these in Vercel's
# Environment Variables. Uses MongoDB Atlas.

# Atlas connection string ("mongodb+srv://..."). Must include a database
# name in the path (e.g. /medibook). A local standalone mongod won't work —
# Prisma requires a replica set, which Atlas provides by default.
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/medibook?retryWrites=true&w=majority"

# Secret used to sign session JWTs.
JWT_SECRET="change_me"
