# Copy to .env and fill in real values. Also set these in Vercel's
# Environment Variables. Uses Neon Postgres.

# Pooled connection string (host contains "-pooler") — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Direct / "unpooled" connection string — used by Prisma for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Secret used to sign session JWTs.
JWT_SECRET="change_me"
