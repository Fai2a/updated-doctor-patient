# Copy to .env and fill in real values. Also set these in Vercel →
# Settings → Environment Variables. Uses MongoDB Atlas via Prisma.

# MongoDB Atlas connection string ("mongodb+srv://..."). MUST include a
# database name in the path (e.g. /medibook). A local standalone mongod won't
# work — the MongoDB provider needs a replica set, which Atlas provides.
# Named MONGODB_URI (not DATABASE_URL) so a leftover Neon/Postgres DATABASE_URL
# in the deployment environment can't be used by mistake.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/medibook?retryWrites=true&w=majority"

# Secret used to sign session JWTs. Required — the app throws without it.
JWT_SECRET="change_me"
